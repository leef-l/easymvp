# EasyMVP Core 环境变量示例
# 复制为 .env 并填入实际值
# 所有配置项也可以通过 GoFrame config.yaml 或 CLI flag 覆盖

# =============================================================================
# 数据目录与数据库
# =============================================================================

# 数据根目录（默认: ./var）
EASYMVP_DATA_ROOT=./var

# SQLite 数据库文件路径（默认: ./var/data/easymvp.db）
EASYMVP_DB_PATH=./var/data/easymvp.db

# SQL 迁移脚本目录（默认: ./manifest/migrations）
EASYMVP_MIGRATION_PATH=./manifest/migrations

# =============================================================================
# HTTP 服务
# =============================================================================

# HTTP 监听地址（默认: :8000）
EASYMVP_SERVER_ADDRESS=:8000

# =============================================================================
# Brain / AI 运行时
# =============================================================================

# Brain 命令路径（环境变量覆盖，代码也支持直接配置）
EASYMVP_BRAIN_CMD=easymvp-brain

# Brain 启动参数（JSON 数组格式）
EASYMVP_BRAIN_ARGS=["--profile", "default", "--config", "./brain-config.yaml"]

# Brain serve base URL（默认: http://127.0.0.1:7701）
EASYMVP_BRAIN_SERVE_BASE_URL=http://127.0.0.1:7701

# Brain 模式: local | remote（默认: local）
EASYMVP_BRAIN_MODE=local

# Brain 本地端点
EASYMVP_BRAIN_LOCAL_ENDPOINT=http://127.0.0.1:7701

# Brain 远程端点
EASYMVP_BRAIN_REMOTE_ENDPOINT=https://brain.easymvp.example.com

# Brain API Key（远程模式需要）
EASYMVP_BRAIN_API_KEY=

# Brain 请求超时（秒，默认: 30）
EASYMVP_BRAIN_TIMEOUT=30

# Brain 最大对话轮数（默认: 6）
EASYMVP_BRAIN_MAX_TURNS=6

# =============================================================================
# 安全模式
# =============================================================================

# Safe mode: true | false（默认: false）
EASYMVP_SAFE_MODE=false

# =============================================================================
# GoFrame 框架级配置（通过 config.yaml 生效）
# =============================================================================
#
# server.address          HTTP 监听地址
# easymvp.dataRoot        数据根目录
# easymvp.dbPath          数据库路径
# easymvp.migrationPath   迁移目录
# easymvp.brainServeBaseURL Brain 服务地址
# easymvp.safeMode        安全模式开关
# easymvp.easymvpBrain.mode            Brain 模式
# easymvp.easymvpBrain.localEndpoint   本地端点
# easymvp.easymvpBrain.remoteEndpoint  远程端点
# easymvp.easymvpBrain.apiKey          API Key
# easymvp.easymvpBrain.timeout         超时
# easymvp.easymvpBrain.maxTurns        最大轮数
