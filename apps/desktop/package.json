{
  "name": "easymvp-desktop",
  "version": "0.1.0",
  "description": "EasyMVP V3 desktop workbench",
  "author": "EasyMVP",
  "private": true,
  "type": "module",
  "main": "dist-electron/src/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -w -p tsconfig.node.json",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/src/main/main.js file:dist-electron/src/preload/preload.js && electron .",
    "build:core": "node ./scripts/build-core.mjs",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.node.json && vite build && tsc -p tsconfig.json",
    "preview": "vite preview",
    "package": "pnpm run build:core && pnpm run build && electron-builder --publish never",
    "package:dir": "pnpm run build:core && pnpm run build && electron-builder --dir --publish never"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.easymvp.desktop",
    "productName": "EasyMVP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/src/main/main.js"
    },
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Development"
    }
  }
}
