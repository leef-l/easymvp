{
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist-electron",
    "target": "ES2020",
    "strict": true
  },
  "include": ["src/main/**/*.ts", "src/preload/**/*.ts"]
}
