# syntax=docker/dockerfile:1

FROM golang:1.24-alpine AS build

WORKDIR /src/apps/core

COPY apps/core/go.mod apps/core/go.sum ./
RUN go mod download

COPY apps/core ./
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/easymvp-core ./main.go

FROM alpine:3.21

RUN addgroup -S easymvp && adduser -S -G easymvp easymvp

WORKDIR /app

COPY --from=build /out/easymvp-core /app/easymvp-core
COPY apps/core/manifest /app/manifest

RUN mkdir -p /app/var && chown -R easymvp:easymvp /app

USER easymvp

EXPOSE 8000

CMD ["/app/easymvp-core"]
