ARG GO_BASE_IMAGE=golang:1.25-bookworm
FROM ${GO_BASE_IMAGE}

ARG GO_PROXY=https://goproxy.cn,direct
ARG PIP_INDEX_URL=https://pypi.org/simple
ARG APT_MIRROR=
ARG APT_SECURITY_MIRROR=

ENV CGO_ENABLED=0 \
    GOPROXY=${GO_PROXY} \
    GOSUMDB=sum.golang.org \
    GOMODCACHE=/go/pkg/mod \
    GOCACHE=/root/.cache/go-build \
    PIP_INDEX_URL=${PIP_INDEX_URL} \
    UV_DEFAULT_INDEX=${PIP_INDEX_URL} \
    UV_INDEX_URL=${PIP_INDEX_URL} \
    UV_LOCK_TIMEOUT=600 \
    UV_PYTHON_INSTALL_DIR=/root/.local/share/uv/python \
    PATH=/root/.local/bin:${PATH}

WORKDIR /workspace/admin-go

RUN if [ -n "${APT_MIRROR}" ] && [ -f /etc/apt/sources.list.d/debian.sources ]; then \
      sed -i "s|http://deb.debian.org/debian|https://${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi \
    && if [ -n "${APT_SECURITY_MIRROR}" ] && [ -f /etc/apt/sources.list.d/debian.sources ]; then \
      sed -i "s|http://deb.debian.org/debian-security|https://${APT_SECURITY_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash ca-certificates git python3 python3-pip \
    && python3 -m pip install -q --default-timeout 120 --retries 10 \
        --break-system-packages \
        -i "${PIP_INDEX_URL}" uv \
    && uv python install 3.12 \
    && uv tool install --python 3.12 aider-chat \
    && uv tool install --python 3.12 openhands \
    && ln -sf /root/.local/share/uv/tools/aider-chat/bin/aider /usr/local/bin/aider \
    && ln -sf /root/.local/share/uv/tools/openhands/bin/openhands /usr/local/bin/openhands \
    && ln -sf /root/.local/share/uv/tools/openhands/bin/openhands-acp /usr/local/bin/openhands-acp \
    && aider --version \
    && openhands --help >/dev/null \
    && rm -rf /var/lib/apt/lists/*

COPY go.mod go.sum ./
RUN go mod download

CMD ["/bin/bash"]
