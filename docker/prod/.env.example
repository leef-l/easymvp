# ═════════════════════════════════════════
# EasyMVP 生产环境配置
# 复制为 .env 并填写实际值
# ═════════════════════════════════════════

# MySQL（使用宿主机数据库）
DB_HOST=host.docker.internal
DB_PORT=3306
MYSQL_USER=easymvp
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=easymvp

# Redis
REDIS_PASSWORD=your_redis_password

# JWT
JWT_SECRET=your_jwt_secret_here

# 端口映射
REDIS_PORT=6379
SYSTEM_PORT=8000
AI_PORT=8001
MVP_PORT=8002
FRONTEND_PORT=5555
NGINX_PORT=80

# 前端 API 地址
VITE_GLOB_API_URL=http://localhost

# MVP 工作目录（项目代码存放的宿主机路径）
WORK_DIR=/www/wwwroot/projects
