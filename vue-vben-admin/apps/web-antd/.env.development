# 端口号
VITE_PORT=5666

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 后端代理目标（本地 gf run）
VITE_PROXY_SYSTEM_TARGET=http://localhost:41002
VITE_PROXY_AI_TARGET=http://localhost:41003
VITE_PROXY_MVP_TARGET=http://localhost:41004

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
